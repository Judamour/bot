# Copier vers .env et remplir avec les vraies valeurs.
# Le fichier .env est lu automatiquement par docker compose.

# NordVPN OpenVPN credentials (gluetun) — exit Canada
NORDVPN_OPENVPN_USER=
NORDVPN_OPENVPN_PASSWORD=

# Polymarket creds — CLOB v2 deposit-wallet flow (sig_type=3, POLY_1271)
# - SIGNER = EOA qui signe les orders (private key dans POLYMARKET_PRIVATE_KEY)
# - FUNDER = proxy v2 (smart contract wallet, balance USDC)
# Les wallets v1 legacy (0x403C... etc.) sont rejetés par le CLOB v2 depuis fin avril 2026.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_SIGNER_ADDRESS=0x7d038bC279b4667fDdB120e1AE9Dec32F0c12977
POLYMARKET_FUNDER_ADDRESS=0x99D43F08883332e9d6b0cc0960e3822193030e06
POLYMARKET_SIG_TYPE=3

# Target wallet (RN1 active depuis 2026-05-18 après switch depuis surfandturf)
COPYTRADE_TARGET_WALLET=RN1

# Sizing — absolute_band (RN1-tuned)
COPYTRADE_SIZING_MODE=absolute_band
COPYTRADE_TIER_PENNY_MAX=0.20
COPYTRADE_TIER_PENNY_SIZE=1.0
COPYTRADE_TIER_SKIP_HIGH=0.45
COPYTRADE_TIER_NORMAL_SIZE=4.5

# Filters (RN1)
COPYTRADE_MAX_POSITIONS=8
COPYTRADE_MAX_USD_PER_MARKET=5.0
COPYTRADE_MIN_TARGET_SIZE_USD=200.0
COPYTRADE_MIN_ENTRY_PRICE=0.06
COPYTRADE_MAX_ENTRY_PRICE=0.95
COPYTRADE_MAX_PRICE_DRIFT=1.30

# Live mode (mettre true pour dry-run / simulation)
COPYTRADE_DRY_RUN=false
COPYTRADE_KILL_EQUITY_USD=0
