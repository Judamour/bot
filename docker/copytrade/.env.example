# Copier vers .env et remplir avec les vraies valeurs.
# Le fichier .env est lu automatiquement par docker compose.

# NordVPN CLI token (déjà dans le .env principal du projet)
TOKEN_NORDVPN=

# Polymarket creds (master account)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_SIGNER_ADDRESS=0x403C2e4C0DA56a8B9DDF6cC3eE70629929Fb4d1c
POLYMARKET_FUNDER_ADDRESS=0x403C2e4C0DA56a8B9DDF6cC3eE70629929Fb4d1c

# Runtime params
COPYTRADE_TARGET_WALLET=surfandturf
COPYTRADE_MAX_POSITIONS=8
COPYTRADE_KILL_EQUITY_USD=0
COPYTRADE_MIN_TARGET_SIZE_USD=1000
COPYTRADE_MIN_ENTRY_PRICE=0.06
COPYTRADE_MAX_ENTRY_PRICE=0.85
COPYTRADE_MAX_PRICE_DRIFT=1.15
COPYTRADE_MAX_USD_PER_MARKET=5.0
COPYTRADE_DRY_RUN=true

# Sizing mode: fixed | tiered | absolute_band
#   - fixed         : flat COPYTRADE_FIXED_SIZE_USD per trade (legacy)
#   - tiered        : scale by entry price + his trade_pct (his conviction)
#   - absolute_band : penny size below TIER_PENNY_MAX, normal size above (no conviction filter)
COPYTRADE_SIZING_MODE=absolute_band
COPYTRADE_FIXED_SIZE_USD=1.5

# Tier grid params (defaults tuned for surfandturf on $40 wallet)
COPYTRADE_TIER_PENNY_MAX=0.20
COPYTRADE_TIER_PENNY_SIZE=1.0
COPYTRADE_TIER_NORMAL_SIZE=4.5
# tiered-only conviction filters (ignored by absolute_band)
COPYTRADE_TIER_PENNY_MIN_CONVICTION=0.03
COPYTRADE_TIER_MID_MAX=0.65
COPYTRADE_TIER_MID_MIN_CONVICTION=0.05
COPYTRADE_TIER_MID_MAX_CONVICTION=0.50
COPYTRADE_TIER_MID_MIN_SIZE=1.5
COPYTRADE_TIER_MID_MAX_SIZE=5.0
COPYTRADE_TIER_FAV_MIN_CONVICTION=0.15
COPYTRADE_TIER_FAV_SIZE=4.5
