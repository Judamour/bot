# Copier vers .env et remplir avec les vraies valeurs.
# Le fichier .env est lu automatiquement par docker compose.

# NordVPN CLI token (déjà dans le .env principal du projet)
TOKEN_NORDVPN=

# Polymarket creds (master account)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_SIGNER_ADDRESS=0x403C2e4C0DA56a8B9DDF6cC3eE70629929Fb4d1c
POLYMARKET_FUNDER_ADDRESS=0x403C2e4C0DA56a8B9DDF6cC3eE70629929Fb4d1c

# Runtime params
COPYTRADE_TARGET_WALLET=surfandturf
COPYTRADE_FIXED_SIZE_USD=1.5
COPYTRADE_MAX_POSITIONS=20
COPYTRADE_KILL_EQUITY_USD=0
COPYTRADE_MIN_TARGET_SIZE_USD=5.0
COPYTRADE_MIN_ENTRY_PRICE=0.06
COPYTRADE_MAX_ENTRY_PRICE=0.85
COPYTRADE_MAX_PRICE_DRIFT=1.15
COPYTRADE_MAX_USD_PER_MARKET=5.0
COPYTRADE_DRY_RUN=true
